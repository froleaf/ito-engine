    {
      "@type": "KnowledgeNode",
      "@id": "ps_compound_emotion_framework",
      "name": "复合情绪框架",
      "academicTerm": "Compound Emotion Framework",
      "description": "六维复合情绪模型：(1)宏大复合细腻——温情渲染伤痛 (2)悲剧复合积极——渺小渲染永恒 (3)仇恨复合悲悯——仇恨渲染爱 (4)残缺渲染圆满——以逝去定义存在 (5)恐惧渲染勇敢——承认软弱方为史诗 (6)孤独渲染羁绊——以记忆对抗虚无。每一组都是通过极致的对立面互相渲染来产生叙事张力。",
      "belongsTo": "domain_psychology",
      "parentNode": "branch_ps_emotion",
      "depth": "理解",
      "nodeRole": "knowledge",
      "userInsight": "用户从鬼灭之刃中提炼出前三维（温情渲染伤痛、渺小渲染永恒、仇恨渲染悲悯），后三维由 Gemini 在用户框架上扩展。用户的核心贡献是提炼方向和音乐-情绪同构的切入角度。",
      "relatedDeposits": ["td_demon_slayer_emotion"],
      "createdAt": "2026-03-09T00:00:00+08:00"
    },
