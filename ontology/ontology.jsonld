    {"_comment": "── 认知科学核心知识节点 ──"},
    {
      "@type": "KnowledgeNode",
      "@id": "cs_marr_three_levels",
      "name": "Marr 三层级框架",
      "academicTerm": "Marr's Three Levels of Analysis",
      "description": "计算层（识别问题与约束）、算法层（从初始到结果的操作）、执行层（物理/神经实现）。计算层靠近哲学/心理学，算法层靠近语言学/数学/计算机，执行层靠近解剖学/影像学。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_foundations",
      "depth": "可教授他人",
      "nodeRole": "tool",
      "mental_model": true,
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "cs_info_processing_four_models",
      "name": "信息处理四模型",
      "description": "物理符号系统（符号+规则，语言式逻辑推演）、神经网络（权重+阈值，亚符号分布式）、贝叶斯概率模型（先验→后验，期望效用决策）、动力学模型（无需中央大脑，组件交互构成系统）。四种模型各有擅长的问题域。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_foundations",
      "depth": "可教授他人",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "cs_act_r_model",
      "name": "ACT-R 认知架构",
      "academicTerm": "Adaptive Control of Thought-Rational",
      "description": "混合架构：感知-运动层 + 认知层（陈述性记忆/程序性记忆/目标系统），通过缓冲区交互。陈述性记忆以知识块存储（激活级别→神经网络模型），程序性记忆以生产规则存储（期望效用→贝叶斯模型），符号化存储层面→物理符号系统。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_foundations",
      "depth": "可教授他人",
      "nodeRole": "tool",
      "mental_model": true,
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "cs_meta_representation",
      "name": "元表征与心智理论",
      "academicTerm": "Meta-representation / Theory of Mind Mechanism (TOMM)",
      "description": "表征是对实体的抽象，元表征是'关于表征的表征'。TOMM三阶段：意向/情绪/眼方向检测（9月前）→共享注意力三元检测（9-14月）→扮演游戏与共情能力发展。自闭症儿童在第二阶段开始异常，缺乏元表征能力导致社交/语言损伤。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_foundations",
      "depth": "可教授他人",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "cs_chinese_room",
      "name": "中文房间与图灵测试",
      "academicTerm": "Chinese Room Argument / Turing Test",
      "description": "Searle的中文房间论证：仅通过规则操纵符号（语法）不等于理解语义，物理符号系统不能产生真正的智能。图灵测试：通过模仿游戏判断机器是否有思考能力。核心哲学争论：语法vs语义、系统回复vs Searle的内化反驳、机器人回复vs鸽子类比。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_consciousness",
      "depth": "可教授他人",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "cs_cheater_detection",
      "name": "说谎检测模块与合作进化",
      "academicTerm": "Cheater Detection Module / Darwinian Modules",
      "description": "达尔文模块假说：认知能力是进化产物，专业化模块解决特定问题。说谎检测模块使人在道义条件推理上远优于普通逻辑推理（Wason选择任务）。通过无限迭代囚徒困境证明：针锋相对策略需要说谎检测能力支撑，这是利他行为/合作行为诞生的基础。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_foundations",
      "depth": "可教授他人",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "cs_chunking_miller",
      "name": "分块与抽象（Miller's 7±2）",
      "academicTerm": "Chunking / Miller's Magical Number Seven",
      "description": "人类信息通道容量约7±2单位。分块与抽象是突破容量限制的高级能力：颜色→赤橙黄绿青蓝紫，音高→C-D-E-F-G-A-B/宫商角徵羽，数字→十进制。学习过程就是先抽象粗略的块，再逐层分层和概念扩充，连接成知识网络。下棋高手看到的是棋谱而非棋子。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_learning",
      "depth": "可教授他人",
      "nodeRole": "tool",
      "mental_model": true,
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "cs_selective_attention",
      "name": "选择性注意力机制",
      "academicTerm": "Selective Attention / Broadbent's Filter Model",
      "description": "鸡尾酒会效应：在嘈杂环境中选择性聚焦特定声音。注意力在感知活动完成前就已介入（ERP实验证据：P1/N1波峰关注组显著强于无视组）。Broadbent过滤器模型：注意力为信息设置瓶颈，保护有限的信息处理通道。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_foundations",
      "depth": "可教授他人",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "cs_brain_anatomy_basics",
      "name": "脑解剖与活动测量技术",
      "description": "脑损伤研究（Phineas Gage：前额叶→人格变化）→侵入性动物实验→非侵入性技术。高时间分辨率：EEG/MEG（脑电波五种：Delta深睡/Theta冥想/Alpha放松/Beta清醒/Gamma快速眼动梦境整理）。高空间分辨率：PET（放射性同位素追踪）/fMRI（血氧水平检测）。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_foundations",
      "depth": "理解",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "cs_language_concept_extension",
      "name": "概念的内在结构与外延",
      "description": "侯世达《表象与本质》：概念通过范畴扩大向外延伸，越到边缘越模棱两可。概念的内在结构极复杂但使用毫不费力——不需要掌握内部方方面面。'枢纽机场'案例：属性延伸赋予母概念新的可能性，是头脑风暴的有效方法。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_learning",
      "depth": "可教授他人",
      "userInsight": "2023.07 深度思考链：从'计算机瘦身的终局是脑机接口'出发，推演出信息沟通的层级结构——文字→语言→抽象概念。GEB中语言学家认为底层抽象机制跨语言一致，侯世达的'枢纽机场'正是这种机制的完美案例。为概念赋予新属性=同时扩充概念的边界，为它可能的物理形态和商业形式都带来新的可能。如果信息沟通能在抽象概念层面实现，语言差异的鸿沟就只剩文化与习俗的差异。",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "cs_machine_human_language_evolution",
      "name": "机器与人类语言的进化",
      "description": "物理符号系统→哥德尔配数（符号规则转化为算数规则）→图灵机→机器语言→汇编语言→编译/解释型语言→NLP。人类语言具有意图/表达、创新性/歧义性/上下文依赖、文化演化性；物理符号系统则是确定/去歧义/上下文无关/恒定。两者鸿沟在于'意图'——NLP正在逼近这一关键差异。",
      "belongsTo": "domain_cognitive_science",
      "parentNode": "branch_cs_foundations",
      "depth": "可教授他人",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },

    {"_comment": "── 系统论知识节点 ──"},
    {
      "@type": "KnowledgeNode",
      "@id": "st_three_problem_domains",
      "name": "问题的三个域（Weinberg）",
      "description": "有序的简单（方程解析，抓住主要矛盾）→无序的复杂（统计方法，大数定律）→有序的复杂（系统化思维）。方程解析受2^n方程数×计算平方律限制；统计方法受大数定律/样本量/随机性限制；现实中最常见的恰恰是第三类'有序的复杂'。",
      "belongsTo": "domain_systems_theory",
      "parentNode": "branch_st_thinking",
      "depth": "可教授他人",
      "nodeRole": "tool",
      "mental_model": true,
      "userInsight": "2023.10 国庆期间的关键领悟：'从来就不是优良的系统管理成就了系统，而是优良的系统成就了系统管理的理论。'系统理论是事后的高度抽象，不是凌驾于系统之上的真理。与音乐理论之于音乐创作的关系相同。",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },

    {"_comment": "── 2025 独立文章知识节点 ──"},
    {
      "@type": "KnowledgeNode",
      "@id": "ps_zero_sum_life",
      "name": "零和博弈人生与复利型成长",
      "description": "将'先苦后甜vs先甜后苦'重构为现在的我与未来的我之间的零和博弈。突破路径：(1)单位时间产能非恒定——能力/学习效率/悟性三层加速度的复利；(2)面向未来的可能性而非稳定性——获得不可逆的能力增长优于积攒可消耗的存粮；(3)了解自我节律——节律里有成功也有懈怠，不是本质。",
      "belongsTo": "domain_psychology",
      "parentNode": "branch_ps_developmental",
      "depth": "有独立见解",
      "nodeRole": "personally_critical",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "ps_optimal_distinctiveness",
      "name": "最优独特性模式",
      "academicTerm": "Optimal Distinctiveness Theory",
      "description": "人类同时追求归属感（平凡的慰藉）和独特性（独特的闪光）。在身份认同上：归属需求vs独特性需求。在审美上：意料之外情理之中的'甜蜜点'。在认知上：大脑过滤冗余和无法解码的信息，最有效学习发生在最近发展区（ZPD）。新旧知识连接的火花带来多巴胺愉悦。",
      "belongsTo": "domain_psychology",
      "parentNode": "branch_ps_cognitive",
      "depth": "有独立见解",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },
    {
      "@type": "KnowledgeNode",
      "@id": "aa_language_as_compression",
      "name": "语言即压缩——与AI交流的底层逻辑",
      "description": "人类语言本质是对多维感官和功能信息的极致压缩（概念化）。关键词/术语/标签是高密度'压缩包'。与AI交流的核心：(1)关键词唤醒——不是输入信息而是唤醒AI网络中已有的知识体系，追求信息压缩率而非信噪比；(2)赋予视角——语言系统切换（领域行话）+认知视角切换（特定立场），防止AI在无限知识网络中迷失。",
      "belongsTo": "domain_ai_agent",
      "parentNode": "branch_aa_prompt",
      "depth": "可教授他人",
      "nodeRole": "personally_critical",
      "outputPotential": "high",
      "createdAt": "2026-03-08T00:00:00+08:00"
    },

